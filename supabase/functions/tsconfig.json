{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "lib": ["esnext", "DOM", "DOM.Iterable"],
    "strict": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "shared/*": ["./shared/*"],
      "https://deno.land/std@0.168.0/http/server.ts": ["./deno.d.ts"],
      "https://esm.sh/@supabase/supabase-js@2": ["../../node_modules/@supabase/supabase-js"],
      "../shared/mrms.ts": ["./shared/mrms.ts"]
    }
  },
  "include": ["./**/*.ts", "./deno.d.ts"]
}
