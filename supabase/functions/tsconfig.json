{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "lib": ["esnext", "DOM", "DOM.Iterable"],
    "strict": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "shared/*": ["./shared/*"],
      "../shared/mrms.ts": ["./shared/mrms.ts"]
    }
  },
  "include": ["./**/*.ts", "./deno.d.ts"]
}
