# Rain API base URL (optional; defaults to https://rain-api.vercel.app)
VITE_RAIN_API_URL=https://rain-api.vercel.app

# Visual Crossing API key (used directly in dev and by capacitor when no proxy is set)
VITE_VISUALCROSSING_KEY=

# Weather proxy origin or full endpoint (optional native fallback, e.g. https://your-app.vercel.app)
VITE_WEATHER_PROXY_URL=

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Weather proxy server variables (configure in Vercel; never use VITE_ prefixes)
SUPABASE_URL=
SUPABASE_ANON_KEY=
VISUALCROSSING_API_KEY=
# Comma-separated exact browser/native origins, e.g. https://acreledger.example,capacitor://localhost
ALLOWED_ORIGINS=

# Live auth integration test only (store real values in .env.test.local)
TEST_BOT_EMAIL=
TEST_BOT_PASSWORD=
